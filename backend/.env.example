PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/recipe-finder
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URL=http://localhost:5173

# Gmail: use your Gmail address and an app password.
EMAIL_SERVICE=gmail
EMAIL_USER=you@example.com
EMAIL_PASS=replace-with-an-app-password
EMAIL_FROM="RecipeFinder <you@example.com>"

# For another SMTP provider, set these instead of EMAIL_SERVICE.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
